# =========================================================================
# Vitamin Mall - 환경 변수 설정 템플릿 (.env.example)
# =========================================================================

# 1. 500GB+ 로컬 스토리지 보관 절대/상대 경로 설정
# (개발용 맥북: 상대 경로 "./test_storage" 사용 권장)
# (배포용 노트북: "D:\\vitamin_images_storage" 또는 "/Users/account/images" 사용 권장)
LOCAL_STORAGE_PATH="./test_storage"

# 2. Neon Serverless PostgreSQL 클라우드 DB 주소
DATABASE_URL="postgresql://username:password@ep-dummy-host.ap-southeast-1.aws.neon.tech/vitamin_mall?sslmode=require"

# 3. Next.js Middleware 도메인 및 클라이언트 가드 설정
CLIENT_HOST="localhost:3000, vitamin-mall.pages.dev"
ADMIN_HOST="admin.localhost:3000, admin-vitamin-mall.pages.dev"
NEXT_PUBLIC_CLIENT_HOST="localhost:3000, vitamin-mall.pages.dev"
NEXT_PUBLIC_ADMIN_HOST="admin.localhost:3000, admin-vitamin-mall.pages.dev"

# 4. Next.js 빌드 시 Prisma 생성을 위한 런타임 (Edge 호환)
NEXT_RUNTIME="edge"
CF_PAGES="true"
